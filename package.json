{
  "name": "daily-routine",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run db:prepare:local && next dev",
    "build": "next build",
    "build:local": "npm run db:prepare:local && next build",
    "build:deploy": "npm run db:prepare:deploy && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:prepare:local": "npm run prisma:generate && npm run prisma:db:push",
    "db:prepare:deploy": "npm run prisma:generate:deploy && npm run prisma:db:push:deploy",
    "prisma:generate": "prisma generate --schema prisma/schema.sqlite.prisma",
    "prisma:generate:deploy": "prisma generate --schema prisma/schema.prisma",
    "prisma:db:push": "prisma db push --schema prisma/schema.sqlite.prisma",
    "prisma:db:push:deploy": "prisma db push --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema prisma/schema.sqlite.prisma",
    "prisma:studio:deploy": "prisma studio --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^5.9.6",
    "lucide-react": "^0.482.0",
    "next": "^15.2.2",
    "nodemailer": "^8.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.55.0",
    "recharts": "^2.15.1",
    "tailwind-merge": "^3.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.21.0",
    "eslint-config-next": "^15.2.2",
    "postcss": "^8.5.3",
    "prisma": "^6.5.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
